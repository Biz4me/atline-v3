# ==========================================
# ATLINE V3 – Variables d'environnement
# Copier ce fichier en .env et compléter
# ==========================================

# Auth (NextAuth v5)
NEXTAUTH_SECRET=changeme_32chars_minimum
NEXTAUTH_URL=http://localhost:3000

# Payload CMS
PAYLOAD_SECRET=changeme_payload_secret
PAYLOAD_API_URL=http://localhost:3002/api
PAYLOAD_API_KEY=

# PostgreSQL (local Docker)
DATABASE_URL=postgresql://atline:atline@localhost:5432/atline

# Redis (quota simulateur + sessions WS)
REDIS_URL=redis://localhost:6379
MONTHLY_QUOTA_SECONDS=7200

# Affiliate Management System
AFFILIATE_API_URL=http://localhost:3003/api
AFFILIATE_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_LICENCE_YEARLY=price_xxx
STRIPE_PRICE_COACH_MONTHLY=price_xxx
STRIPE_PRICE_EXTRA_HOUR=price_xxx

# Simulateur Vocal
DEEPGRAM_API_KEY=
GROQ_API_KEY=
CARTESIA_API_KEY=

# Dify
DIFY_API_URL=http://localhost:5001/v1
DIFY_CHAT_KEY=
DIFY_DEBRIEF_KEY=

# OpenClaw
OPENCLAW_API_URL=http://localhost:4000
OPENCLAW_API_KEY=

# Cal.com
CALCOM_API_URL=http://localhost:5050/api/v1
CALCOM_API_KEY=

# Brevo (email + SMS)
BREVO_API_KEY=

# Next.js public vars (exposées au client)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001
