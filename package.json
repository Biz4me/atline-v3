{
  "name": "atline-v3",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "dev:app": "turbo dev --filter=@atline/next-app",
    "dev:ws": "turbo dev --filter=@atline/ws-server",
    "dev:payload": "turbo dev --filter=@atline/payload-cms"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}
